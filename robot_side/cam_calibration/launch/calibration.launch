<?xml version="1.0"?>
<launch>
    <!-- 标定-->
    <arg name="markers_x" default="3" />
    <arg name="markers_y" default="4" />
    <arg name="marker_size" default="0.0564" />
    <arg name="marker_separation" default="0.0057" />

    <!-- <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" /> -->

    <param name="robot_description" textfile="$(find piper_description)/urdf/piper_description.urdf" />
    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" >
        <rosparam param="source_list">[/robot/arm_left/joint_states_single]</rosparam>
    </node>
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find cam_calibration)/rviz/default.rviz" />


    <!-- 目标板位姿检测-->
    <!-- <include file="$(find cam_calibration)/launch/detect_target.launch">
        <arg name="node_prefix" default="left" />
        <arg name="image_topic" default="/realsense_left/color/image_raw" />
        <arg name="camera_info_topic" default="/realsense_left/color/camera_info" />
        <arg name="target_pose_topic" default="/handeye/left_cam_from_target" />
        <arg name="aruco_dict" default="DICT_5X5_250" />
        <arg name="markers_x" value="$(arg markers_x)" />
        <arg name="markers_y" value="$(arg markers_y)" />
        <arg name="marker_size" value="$(arg marker_size)" />
        <arg name="marker_separation" value="$(arg marker_separation)" />
        <arg name="show_visualization" default="true" />
    </include>

    <include file="$(find cam_calibration)/launch/detect_target.launch">
        <arg name="node_prefix" default="top" />
        <arg name="image_topic" default="/realsense_top/color/image_raw" />
        <arg name="camera_info_topic" default="/realsense_top/color/camera_info" />
        <arg name="target_pose_topic" default="/handeye/top_cam_from_target" />
        <arg name="aruco_dict" default="DICT_5X5_250" />
        <arg name="markers_x" value="$(arg markers_x)" />
        <arg name="markers_y" value="$(arg markers_y)" />
        <arg name="marker_size" value="$(arg marker_size)" />
        <arg name="marker_separation" value="$(arg marker_separation)" />
        <arg name="show_visualization" default="true" />
    </include> -->

    <!-- 发布 handeye TF（gripper -> camera） -->
    <node pkg="cam_calibration" type="tf_publisher.py" name="handeye_tf_publisher" output="screen">
        <!-- 可选：指定特定标定文件；若为空自动选择最新 handeye_data_*.json -->
        <param name="trajectory_file" value="" />
        <param name="parent_frame" value="gripper_base" />
        <param name="child_frame" value="realsense_left_color_optical_frame" />
        <param name="publish_rate" value="100.0" />
    </node>
</launch>