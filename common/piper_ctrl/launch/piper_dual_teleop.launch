<launch>
  <!-- 
    Piper Dual Teleop Launch
    All parameters are loaded from config/piper_dual.yaml
    Modify the yaml file to change topic mappings (no need to modify this launch file)
  -->

  <!-- Load node-specific parameters from piper_dual.yaml -->
  <!-- Parameters under node name keys are automatically loaded to each node's private namespace -->
  <rosparam file="$(find piper_ctrl)/config/piper_dual.yaml" command="load"/>

  <!-- Left arm node -->
  <node name="piper_teleop_left_node" pkg="piper_ctrl" type="piper_ctrl_node.py" output="screen">
    <!-- Load common control config -->
    <rosparam file="$(find piper_ctrl)/config/piper_ctrl_mit_gravity.yaml" command="load"/>
    <!-- Node-specific params (can_port, topic_prefix, remap, enable_gripper_haptic) are loaded from piper_dual.yaml above -->
  </node>
  
  <!-- Right arm node -->
  <node name="piper_teleop_right_node" pkg="piper_ctrl" type="piper_ctrl_node.py" output="screen">
    <!-- Load common control config -->
    <rosparam file="$(find piper_ctrl)/config/piper_ctrl_mit_gravity.yaml" command="load"/>
    <!-- Node-specific params (can_port, topic_prefix, remap, enable_gripper_haptic) are loaded from piper_dual.yaml above -->
  </node>
</launch>
